<Window x:Class="MyCalk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator" Height="400" Width="300" ResizeMode="CanMinimize">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>

			<RowDefinition Height="*"/>

		</Grid.RowDefinitions>

		<TextBox x:Name="Display" Grid.Row="0" Height="50" FontSize="28" 
                 HorizontalAlignment="Stretch" Margin="10"
                 IsReadOnly="True" Text="0" TextAlignment="Right"/>

		<UniformGrid Grid.Row="1" Margin="10" Rows="5" Columns="4" >
			<!-- Кнопки цифр -->
			<Button Content="7" Click="Button_Click" FontSize="20"/>
			<Button Content="8" Click="Button_Click" FontSize="20"/>
			<Button Content="9" Click="Button_Click" FontSize="20"/>
			<Button Content="/" Click="Operation_Click" FontSize="20" Foreground="Blue"/>

			<Button Content="4" Click="Button_Click" FontSize="20"/>
			<Button Content="5" Click="Button_Click" FontSize="20"/>
			<Button Content="6" Click="Button_Click" FontSize="20"/>
			<Button Content="*" Click="Operation_Click" FontSize="20" Foreground="Blue"/>

			<Button Content="1" Click="Button_Click" FontSize="20"/>
			<Button Content="2" Click="Button_Click" FontSize="20"/>
			<Button Content="3" Click="Button_Click" FontSize="20"/>
			<Button Content="-" Click="Operation_Click" FontSize="20" Foreground="Blue"/>

			<Button Content="0" Click="Button_Click" FontSize="20" />
			<Button Content="." Click="Button_Click" FontSize="20" />
			<Button Content="+" Click="Operation_Click" FontSize="20" Foreground="Blue"/>
			<Button Content="^" Click="Button_Click" FontSize="20" Foreground="Blue"/>

			<Button Content="(" Click="Button_Click" FontSize="20" Foreground="Blue"/>
			<Button Content=")" Click="Button_Click" FontSize="20" Foreground="Blue"/>

			<Button Content="=" Click="Equals_Click" FontSize="20" Background="LightGreen"/>
			<Button Content="C" Click="Clear_Click" FontSize="20" Background="LightCoral" Grid.ColumnSpan="4"/>
		</UniformGrid>
	</Grid>
</Window>
